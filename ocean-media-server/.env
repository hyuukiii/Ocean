# MediaSoup Server Configuration
PORT=3001

# MediaSoup Listen IP (로컬 개발용) 에이콘 아카데미 IP : 172.30.1.49 투썸플레이스 신촌점 : 192.168.40.6 집 와이파이 : 192.168.0.16
#MEDIASOUP_LISTEN_IP=127.0.0.1
#MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=192.168.0.16


# MediaSoup Worker Settings
MEDIASOUP_WORKER_LOGTYPE=info
MEDIASOUP_WORKER_LOGLEVEL=debug

# RTC Port Range
RTC_MIN_PORT=10000
RTC_MAX_PORT=10100